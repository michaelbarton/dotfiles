[submodule "zsh-git"]
	path = zsh-git
	url = git://github.com/jcorbin/zsh-git.git
[submodule "dircolors-solarized"]
	path = dircolors-solarized
	url = git://github.com/seebi/dircolors-solarized.git
[submodule "solarized"]
	path = solarized
	url = git://github.com/altercation/solarized.git
[submodule "git/.zsh"]
	path = git/.zsh
	url = git@github.com:jcorbin/zsh-git.git
[submodule "git/.zsh-git"]
	path = git/.zsh-git
	url = git@github.com:jcorbin/zsh-git.git
